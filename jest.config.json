{
    "displayName": "project-structure-api-test",
    "preset": "ts-jest",
    "verbose": true,
    "roots": ["src/"],
    "collectCoverage": true,
    "collectCoverageFrom": [
        "**/src/api/models/**",
        "**/src/api/repositories/**",
        "**/src/api/services/**",
        "!**/src/api/repositories/__test__/**",
        "!**/src/api/services/__test__/**"
    ],
    "transform": {
        "^.+\\.ts$": [
            "ts-jest",
            {
                "tsconfig": "tsconfig.json",
                "diagnostics": {
                    "ignoreDiagnostics": [151002]
                }
            }
        ]
    }
}
